{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {},
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "https://litellm.heywood.dev/v1"
      },
      "models": {
        "laguna-m.1": {
          "name": "Laguna M.1"
        },
        "laguna-xs.2": {
          "name": "Laguna XS.2"
        },
        "gpt-5.4": {
          "name": "GPT-5.4",
          "limit": { "context": 128000, "output": 32768 }
        },
        "gpt-5.4-pro": {
          "name": "GPT-5.4 Pro",
          "limit": { "context": 128000, "output": 32768 }
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "limit": { "context": 192000, "output": 16384 }
        },
        "gpt-5.3-codex-spark": {
          "name": "GPT-5.3 Codex Spark",
          "limit": { "context": 192000, "output": 16384 }
        },
        "gpt-5.3-instant": {
          "name": "GPT-5.3 Instant",
          "limit": { "context": 128000, "output": 16384 }
        },
        "gpt-5.3-chat-latest": {
          "name": "GPT-5.3 Chat Latest",
          "limit": { "context": 128000, "output": 16384 }
        },
        "gemma4": {
          "name": "Gemma 4 (local)",
          "limit": { "context": 128000, "output": 8192 }
        },
        "nomic-embed-text": {
          "name": "Nomic Embed Text",
          "limit": { "context": 8192, "output": 0 }
        }
      }
    },
    "poolside": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Poolside",
      "options": {
        "baseURL": "https://inference.poolside.ai/v1"
      },
      "models": {
        "poolside/laguna-m.1": {
          "name": "Laguna M.1"
        },
        "poolside/laguna-xs.2": {
          "name": "Laguna XS.2"
        }
      }
    }
  },
}